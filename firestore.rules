rules_version = '2';

// Security rules for the GoalPost global daily leaderboard.
// Layout: leaderboards/{day}/scores/{uid}
service cloud.firestore {
  match /databases/{database}/documents {

    match /leaderboards/{day}/scores/{uid} {
      // Anyone signed in (incl. anonymous) can read the board.
      allow read: if request.auth != null;

      // A user may only write their OWN entry, and only with a plausible,
      // well-formed, bounded score. This is the server-side validation that
      // stops clients from injecting arbitrary or impossible scores.
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 20000
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 20
        && request.resource.data.keys().hasOnly(['name', 'avatar', 'country', 'score', 'updatedAt']);

      allow delete: if false;
    }
  }
}
