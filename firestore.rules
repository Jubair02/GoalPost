rules_version = '2';

// Security rules for the GoalPost global season leaderboard.
// Rankings accumulate per calendar month, then reset for the next season.
// Layout: leaderboards/{YYYY-MM}/scores/{uid}
//
// The board is fed ONLY by the Daily Challenge. Since the free (Spark) plan has
// no server compute to recompute a quiz, these rules instead make the score
// tamper-resistant by constraining HOW it can change (Google enforces this
// server-side, so a modified client can't bypass it):
//   • one entry per user (uid = doc id, owner-only writes)
//   • score can only ever INCREASE
//   • each write may add at most ONE daily's worth of points (MAX_DAILY)
//   • the day key must strictly advance  → ~one bump per calendar day
//   • updatedAt must be a genuine server timestamp (can't be spoofed)
// This blocks the "set score = 499999 in one shot" attack and caps inflation to
// the same rate an honest top player achieves. (A perfect daily ≈ 3265 pts.)
service cloud.firestore {
  match /databases/{database}/documents {

    // Max points a single Daily Challenge can yield (headroom over ~3265).
    function maxDaily() { return 3500; }

    // Well-formed, bounded leaderboard row written with a real server timestamp.
    function validEntry(d) {
      return d.score is number
        && d.score >= 0
        && d.score <= 500000
        && d.name is string && d.name.size() <= 20
        && d.avatar is map
        && d.country is string && d.country.size() <= 8
        && d.lastDay is string && d.lastDay.size() <= 10
        && d.updatedAt == request.time
        && d.keys().hasOnly(['name', 'avatar', 'country', 'score', 'updatedAt', 'lastDay']);
    }

    match /leaderboards/{period}/scores/{uid} {
      // Anyone signed in (incl. anonymous) can read the board.
      allow read: if request.auth != null;

      // First entry of the season — a single daily's worth, at most.
      allow create: if request.auth != null
        && request.auth.uid == uid
        && validEntry(request.resource.data)
        && request.resource.data.score <= maxDaily();

      // Subsequent bumps: score only increases, by ≤ one daily, and the day
      // must advance — so a client can't inflate its total arbitrarily.
      allow update: if request.auth != null
        && request.auth.uid == uid
        && validEntry(request.resource.data)
        && request.resource.data.score >= resource.data.score
        && request.resource.data.score - resource.data.score <= maxDaily()
        && request.resource.data.lastDay > resource.data.lastDay;

      allow delete: if false;
    }

    // Challenge-by-code live Battle. A host creates a match; a guest claims it
    // by code. Each player may write ONLY their own players/{uid} row, so no one
    // can forge the opponent's score. There's no server arbiter (Spark plan), so
    // scores remain client-reported — acceptable for a friendly 1v1.
    match /matches/{code} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == "waiting";

      // Host may update their own match; the existing guest may update; and a new
      // guest may claim an OPEN waiting match (but can't hijack an active one).
      allow update: if request.auth != null && (
        resource.data.hostUid == request.auth.uid
        || resource.data.guestUid == request.auth.uid
        || (resource.data.status == "waiting" && !("guestUid" in resource.data)
            && request.resource.data.guestUid == request.auth.uid)
      );

      allow delete: if request.auth != null && resource.data.hostUid == request.auth.uid;

      match /players/{uid} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Private per-user profile: the single source of truth for a player's data
    // (profile, XP, coins, stats, achievements, season score). Accessible ONLY
    // by its owner — this is what ties all user data to one uid.
    match /players/{uid} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;

      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 20
        && request.resource.data.xp is number
        && request.resource.data.xp >= 0;
    }
  }
}
